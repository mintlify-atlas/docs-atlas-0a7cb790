  "keyFeatures": [
    "Android and iOS instance management",
    "Real-time device control via WebSocket",
    "Asset management and deployment",
    "TCP tunneling for ADB and debugging",
    "Xcode build sandbox with hot reload",
    "Folder synchronization with delta patching",
    "Auto-pagination for list operations",
    "Built-in retry logic and error handling",
    "TypeScript-first with comprehensive types",
    "Multiple runtime support (Node, Deno, Bun, Cloudflare Workers)"
  ],
